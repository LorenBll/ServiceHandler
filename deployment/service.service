# systemd unit for the service. Update user and paths before installation.

[Unit]
Description=PortHandler
After=network.target

[Service]
Type=simple
User=yourusername
WorkingDirectory=/path/to/PortHandler
ExecStart=/path/to/PortHandler/.venv/bin/python src/main.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
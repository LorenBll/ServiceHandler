# ServiceHandler Configuration
# Copy this file to .env and fill in the values for your environment.

# JSON object mapping service names to plain API keys.
# Loaded at session initialization.
# SH_API_KEYS={}

# UI/Behavior settings (moved from configuration.json)
# Set to "true" to disable all UI-related endpoints.
# SH_NO_GUI=false

# JSON array defining the column sort order for the web UI.
# SH_SORT_ORDER=["name","port","pid","bind_address","hostname","status","protected"]

# Fuzzy matching threshold (0-100). Default: 30.
# SH_ACCURACY=30

# Key to group services by (e.g., "name", "protected", "status"). Leave empty to ungroup.
# SH_GROUP_BY=protected

# JSON array for the original/ungrouped sort order.
# SH_ORIGINAL_SORT_ORDER=["status","protected","port","name","bind_address","hostname","pid"]
